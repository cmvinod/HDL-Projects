/**
 * Memory of sixty four 16-bit registers.
 * If load is asserted, the value of the register selected by
 * address is set to in; Otherwise, the value does not change.
 * The value of the selected register is emitted by out.
 */
CHIP RAM64 {
    IN in[16], load, address[6];
    OUT out[16];

    PARTS:
    //// Replace this comment with your code.
    DMux8Way(in=load , sel=address[3..5], a=loadRAM0, b=loadRAM1 , c=loadRAM2 , d=loadRAM3, e=loadRAM4, f=loadRAM5, g=loadRAM6, h=loadRAM7 );

    RAM8(in=in , load=loadRAM0, address=address[0..2], out=RAM0data);
    RAM8(in=in , load=loadRAM1, address=address[0..2], out=RAM1data);
    RAM8(in=in , load=loadRAM2, address=address[0..2], out=RAM2data);
    RAM8(in=in , load=loadRAM3, address=address[0..2], out=RAM3data);
    RAM8(in=in , load=loadRAM4, address=address[0..2], out=RAM4data);
    RAM8(in=in , load=loadRAM5, address=address[0..2], out=RAM5data);
    RAM8(in=in , load=loadRAM6, address=address[0..2], out=RAM6data);
    RAM8(in=in , load=loadRAM7, address=address[0..2], out=RAM7data);
    
    Mux8Way16(a=RAM0data , b=RAM1data, c=RAM2data, d=RAM3data, e=RAM4data, f=RAM5data, g=RAM6data, h=RAM7data, sel=address[3..5], out=out );
}